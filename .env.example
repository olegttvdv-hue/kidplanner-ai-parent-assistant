# Demo configuration only. Do not put real secrets here.

# Telegram
TELEGRAM_BOT_TOKEN=DEMO_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=demo_kidplanner_bot

# OpenAI
OPENAI_API_KEY=DEMO_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# n8n
N8N_TELEGRAM_WEBHOOK_URL=https://n8n.example.com/webhook/kidplanner-telegram
N8N_PAYMENT_WEBHOOK_URL=https://n8n.example.com/webhook/kidplanner-payment

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=kidplanner_demo_db
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=CHANGE_ME_LOCALLY

# Payment Provider Demo
PAYMENT_PROVIDER=demo_provider
PAYMENT_SHOP_ID=DEMO_SHOP_ID
PAYMENT_SECRET_KEY=DEMO_SECRET_KEY

# Limits
FREE_DAILY_REQUEST_LIMIT=5
PAID_EXTRA_REQUESTS=50
